# ARC-1 Environment Configuration
# Copy this file to .env and uncomment values you need.
#
# Priority: CLI flags > Environment variables > .env > Defaults

# === SAP connection (required) ===
# SAP_URL=http://sapdev:50000
# SAP_CLIENT=001
# SAP_LANGUAGE=EN
# SAP_INSECURE=false
# SAP_SYSTEM_TYPE=auto                # auto | btp | onprem

# === Layer B: ARC-1 → SAP authentication (pick ONE) ===
# Fail-fast rules (validated at startup):
#   ppEnabled + cookieFile|cookieString         →  error (unless SAP_PP_ALLOW_SHARED_COOKIES=true)
#   btpServiceKey + cookieFile|cookieString     →  error
#   btpServiceKey + ppEnabled                   →  error
#   disableSaml + systemType=btp                →  warning (continues)

# (B1) Basic Auth
# SAP_USER=YOUR_USERNAME
# SAP_PASSWORD=YOUR_PASSWORD

# (B2) Cookie auth (on-prem SSO developer loops — see scripts/extract-sap-cookies.ts)
# WARNING: Never combine with SAP_PP_ENABLED=true without SAP_PP_ALLOW_SHARED_COOKIES=true.
# SAP_COOKIE_FILE=/path/to/cookies.txt
# SAP_COOKIE_STRING=sap-usercontext=abc; SAP_SESSIONID=xyz

# (B3) BTP ABAP Environment (direct OAuth)
# SAP_BTP_SERVICE_KEY_FILE=/path/to/service-key.json
# SAP_BTP_SERVICE_KEY={"uaa":{"url":"...","clientid":"...","clientsecret":"..."},"url":"..."}
# SAP_BTP_OAUTH_CALLBACK_PORT=0       # 0 = auto-assign

# (B4) BTP Destination Service (Cloud Foundry)
# SAP_BTP_DESTINATION=SAP_TRIAL
# SAP_BTP_PP_DESTINATION=SAP_TRIAL_PP

# (B5) Principal Propagation (per-user SAP identity)
# SAP_PP_ENABLED=false
# SAP_PP_STRICT=false                 # true = PP failure is error, no fallback
# SAP_PP_ALLOW_SHARED_COOKIES=false   # escape hatch; shared client only

# Extras: SAP_DISABLE_SAML (opt-in, advanced, breaks BTP ABAP / S/4 Public Cloud)
# SAP_DISABLE_SAML=false

# === Layer A: MCP Client → ARC-1 authentication (can combine) ===
# (A1) No auth (stdio only, local dev)
# (Set nothing)

# (A2) API Key(s)
# ARC1_API_KEY=your-api-key-here
# ARC1_API_KEYS=key1:viewer,key2:developer

# (A3) OIDC / JWT
# SAP_OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# SAP_OIDC_AUDIENCE=api://your-app-id
# SAP_OIDC_CLOCK_TOLERANCE=0

# (A4) XSUAA OAuth (BTP)
# SAP_XSUAA_AUTH=false

# === Safety / scopes / profiles ===
# SAP_READ_ONLY=true
# SAP_BLOCK_DATA=true
# SAP_BLOCK_FREE_SQL=true
# SAP_ALLOWED_OPS=RSQ
# SAP_DISALLOWED_OPS=
# SAP_ALLOWED_PACKAGES=$TMP            # Use * for unrestricted
# SAP_ENABLE_TRANSPORTS=false
# ARC1_PROFILE=viewer                  # viewer | viewer-data | viewer-sql | developer | developer-data | developer-sql
# ARC1_TOOL_MODE=standard              # standard | hyperfocused

# === Transport & logging ===
# SAP_TRANSPORT=stdio                  # stdio (default) | http-streamable
# ARC1_HTTP_ADDR=0.0.0.0:8080
# SAP_HTTP_ADDR=0.0.0.0:8080           # compatibility alias
# ARC1_PORT=8080
# ARC1_LOG_FILE=/path/to/arc1.log
# ARC1_LOG_LEVEL=info                  # debug | info | warn | error
# ARC1_LOG_FORMAT=text                 # text | json
# SAP_VERBOSE=false

# === Cache & concurrency ===
# ARC1_CACHE=auto                      # auto | memory | sqlite | none
# ARC1_CACHE_FILE=.arc1-cache.db
# ARC1_CACHE_WARMUP=false
# ARC1_CACHE_WARMUP_PACKAGES=Z*,Y*
# ARC1_MAX_CONCURRENT=10

# ---------------------------------------------------------------------------
# Integration Test Connection (optional)
# ---------------------------------------------------------------------------
# Use TEST_SAP_* variables to point integration tests at a dedicated SAP system.
# TEST_SAP_* takes priority over SAP_* for all integration tests.
#
# Run integration tests:
#   npm run test:integration
#
# If neither TEST_SAP_* nor SAP_* are set, integration tests are skipped.
#
# TEST_SAP_URL=http://your-sap-host:50000
# TEST_SAP_USER=YOUR_TEST_USERNAME
# TEST_SAP_PASSWORD=YOUR_TEST_PASSWORD
# TEST_SAP_CLIENT=001
# TEST_SAP_LANGUAGE=EN
# TEST_SAP_INSECURE=false
