# ──────────────────────────────────────────────────────────────────────
# MTA Extension Descriptor — Environment-Specific Overrides
#
# Uncomment and set values to override the safe defaults in mta.yaml.
# Any property left commented uses the mta.yaml value unchanged.
#
# Build the archive:
#   mbt build
#
# Deploy with extension:
#   cf deploy mta_archives/arc1-mcp_<version>.mtar -e mta-overrides.mtaext
# ──────────────────────────────────────────────────────────────────────

_schema-version: "3.1"
ID: arc1-mcp-overrides
extends: arc1-mcp

modules:
  - name: arc1-mcp-server
    properties:
      # ── Destinations ─────────────────────────────────────────────────
      # BasicAuth destination for startup (feature probing, cache warmup)
      # SAP_BTP_DESTINATION: "my-basic-auth-destination"

      # PrincipalPropagation destination for per-user requests (with JWT)
      # SAP_BTP_PP_DESTINATION: "my-pp-destination"

      # Enable per-user principal propagation
      # SAP_PP_ENABLED: "true"

      # ── Safety / Authorization ───────────────────────────────────────
      # Enable object mutations (create, update, delete)
      # SAP_ALLOW_WRITES: "true"

      # Enable named table data preview (SELECT * FROM <table>)
      # SAP_ALLOW_DATA_PREVIEW: "true"

      # Enable freestyle SQL execution
      # SAP_ALLOW_FREE_SQL: "true"

      # Enable transport mutations (release, create, add to transport)
      # SAP_ALLOW_TRANSPORT_WRITES: "true"

      # Enable abapGit mutations (push, pull, create repo)
      # SAP_ALLOW_GIT_WRITES: "true"

      # Restrict writes to these packages (comma-separated, supports wildcards)
      # SAP_ALLOWED_PACKAGES: "Z*,Y*,$TMP"

      # ── CORS ─────────────────────────────────────────────────────────
      # Allow browser-based UIs to call /mcp directly.
      # Not needed for native MCP clients (Claude Desktop, Cursor, etc.)
      # Comma-separated, exact origin match, no wildcards.
      # ARC1_ALLOWED_ORIGINS: "https://my-app.cfapps.eu10.hana.ondemand.com"

      # ── System Connection ────────────────────────────────────────────
      # Override system type detection (auto | btp | onprem)
      # SAP_SYSTEM_TYPE: "auto"

      # SAP client number (if not using destination)
      # SAP_CLIENT: "100"

      # SAP language
      # SAP_LANGUAGE: "EN"

      # Skip TLS certificate verification
      # SAP_INSECURE: "true"
